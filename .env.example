# ─── Peer signaling server (Node process) ────────────────────────────────────
PEERJS_PORT=9000
PEERJS_PATH=/peerjs

# ─── Next.js client ───────────────────────────────────────────────────────────
# Must be prefixed NEXT_PUBLIC_ to be exposed to the browser.
NEXT_PUBLIC_PEER_HOST=localhost
NEXT_PUBLIC_PEER_PORT=9000
NEXT_PUBLIC_PEER_PATH=/peerjs
