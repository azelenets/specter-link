{
  "name": "specter-link",
  "author": "Andrii Zelenets <andrew.zelenets@gmail.com>",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"ts-node --project tsconfig.server.json server/peer-server.ts\" \"next dev\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.server.json",
    "build": "next build",
    "prepare": "lefthook install",
    "start:server": "ts-node --project tsconfig.server.json server/peer-server.ts",
    "start:next": "next start"
  },
  "dependencies": {
    "@azelenets/aegis-design-system": "latest",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "next": "latest",
    "peer": "^1.0.2",
    "peerjs": "^1.5.4",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.4.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "@playwright/test": "^1.49.0",
    "lefthook": "^2.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
